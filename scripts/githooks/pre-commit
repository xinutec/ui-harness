#!/usr/bin/env bash
# Single health gate. A commit must be healthy: this runs the full verify
# (scripts/verify.sh) — backend + frontend + shared dev-lint rules, plus any
# generated-type drift folded into verify. There is NO separate pre-push step.
# Slow by design; we optimise for healthy commits, not commit speed.
# Bypass a genuine work-in-progress commit with:  git commit --no-verify
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
exec scripts/verify.sh
